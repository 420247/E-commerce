<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Checkstyle configuration based on Google Java Style Guide.
  Relaxed for a student project — focuses on the most important rules.

  Run locally: ./mvnw checkstyle:check
  Auto-fix:    your IDE (IntelliJ: Code → Reformat Code, Ctrl+Alt+L)
-->
<module name="Checker">
  <property name="charset" value="UTF-8"/>
  <property name="severity" value="error"/>
  <property name="fileExtensions" value="java"/>

  <!-- Files must end with a newline -->
  <module name="NewlineAtEndOfFile"/>

  <!-- No trailing whitespace -->
  <module name="RegexpSingleline">
    <property name="format" value="\s+$"/>
    <property name="minimum" value="0"/>
    <property name="maximum" value="0"/>
    <property name="message" value="Line has trailing whitespace."/>
  </module>

  <module name="TreeWalker">

    <!-- ── Imports ──────────────────────────────────────────── -->
    <!-- No wildcard imports like java.util.* -->
    <module name="AvoidStarImport"/>
    <!-- No unused imports -->
    <module name="UnusedImports"/>
    <!-- No duplicate imports -->
    <module name="RedundantImport"/>

    <!-- ── Naming conventions ───────────────────────────────── -->
    <!-- Class names: UpperCamelCase -->
    <module name="TypeName"/>
    <!-- Method names: lowerCamelCase -->
    <module name="MethodName"/>
    <!-- Variable names: lowerCamelCase, min 2 chars (except i, j, k loop vars) -->
    <module name="LocalVariableName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
    </module>
    <!-- Constants: UPPER_SNAKE_CASE -->
    <module name="ConstantName"/>

    <!-- ── Whitespace ───────────────────────────────────────── -->
    <!-- No tabs — use spaces -->
    <module name="TabCharacter"/>
    <!-- Space after commas: method(a, b) not method(a,b) -->
    <module name="WhitespaceAfter">
      <property name="tokens" value="COMMA, SEMI"/>
    </module>

    <!-- ── Braces ────────────────────────────────────────────── -->
    <!-- Always use braces for if/for/while even for single-line bodies -->
    <module name="NeedBraces"/>
    <!-- Opening brace on same line: if (x) { -->
    <module name="LeftCurly"/>
    <!-- Closing brace on its own line -->
    <module name="RightCurly"/>

    <!-- ── Code quality ─────────────────────────────────────── -->
    <!-- No empty catch blocks (except with a comment explaining why) -->
    <module name="EmptyCatchBlock">
      <property name="exceptionVariableName" value="expected|ignored"/>
    </module>
    <!-- No empty blocks -->
    <module name="EmptyBlock"/>
    <!-- Equals and hashCode must be overridden together -->
    <module name="EqualsHashCode"/>
    <!-- No System.out.println (use a logger) -->
    <module name="Regexp">
      <property name="format" value="System\.out\.println"/>
      <property name="illegalPattern" value="true"/>
      <property name="message" value="Use a logger instead of System.out.println."/>
    </module>

    <!-- ── Complexity ───────────────────────────────────────── -->
    <!-- Max method length: 60 lines -->
    <module name="MethodLength">
      <property name="max" value="60"/>
    </module>
    <!-- Max parameters per method: 7 -->
    <module name="ParameterNumber">
      <property name="max" value="7"/>
    </module>

  </module>
</module>
