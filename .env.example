# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must NEVER be committed to the repository.

# PostgreSQL — used by docker-compose for local development
POSTGRES_DB=ecommerce
POSTGRES_USER=
POSTGRES_PASSWORD=

# Anthropic Claude API key — get it from console.anthropic.com
ANTHROPIC_API_KEY=

# JWT signing key — must be a Base64-encoded string of at least 256 bits.
# The value below is safe to use for local development only.
# Generate a new one for production: openssl rand -hex 32
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970